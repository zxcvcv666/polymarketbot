
# ===========================================
# Polymaker 量化机器人配置文件示例
# 复制此文件为 .env 并填写实际值
# ===========================================

# ------------------
# Polymarket API 配置
# ------------------
# Polymarket 生成的钱包私钥（用于签名交易）
PRIVATE_KEY=0x...

# Polymarket 平台交易地址（由上述私钥控制的地址）
ADDRESS=0x...

# Funder 地址（用于 gasless 交易，通常与 ADDRESS 相同）
FUNDER_ADDRESS=0x...

# ------------------
# Builder Program 配置（Gasless 交易）
# ------------------
# Builder API Key（从 Polymarket Builder Program 获取）
POLY_BUILDER_API_KEY=

# Builder Secret（从 Polymarket Builder Program 获取）
POLY_BUILDER_SECRET=

# Builder Passphrase（从 Polymarket Builder Program 获取）
POLY_BUILDER_PASSPHRASE=

# 签名类型：1 = POLY_PROXY, 2 = GNOSIS_SAFE
# 推荐使用 1 (POLY_PROXY) 用于 Builder Program
SIGNATURE_TYPE=1

# ------------------
# Telegram 配置
# ------------------
# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=

# Telegram 用户 ID（接收消息的用户ID）
TELEGRAM_CHAT_ID=

# ------------------
# 交易参数配置
# ------------------
# 每次交易的份额数量（默认6股）
TRADE_SIZE=6

# 最大持仓价值上限（USDC）
MAX_EXPOSURE_USD=100.0

# 最小距离结算时间（秒）
MIN_SETTLE_SECONDS=120

# 最大未实现亏损比例
MAX_LOSS_RATIO=0.10

# ------------------
# 套利参数配置
# ------------------
# 最小深度要求（USDC）
MIN_DEPTH_USD=300

# 最大双边 bid 价格和（当 UP bid + DOWN bid < 此值时存在套利机会）
MAX_BID_SUM=0.99

# 安全价格和上限（挂单价格之和不能超过此值）
SAFE_PRICE_SUM=0.98

# 订单有效期（秒）
ORDER_EXPIRATION_SECONDS=15

# 订单轮询间隔（秒）
ORDER_POLL_INTERVAL=1

# ------------------
# 风控参数配置
# ------------------
# 最大滑点容忍度
MAX_SLIPPAGE_RATIO=0.05

# API 重试次数
API_RETRY_COUNT=3

# API 重试间隔基数（秒）
API_RETRY_BASE_DELAY=1

# ------------------
# 系统配置
# ------------------
# 日志文件路径
LOG_FILE=trades.log

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# SQLite 数据库路径
DATABASE_PATH=polymaker.db

# 报表目录
REPORTS_DIR=reports
